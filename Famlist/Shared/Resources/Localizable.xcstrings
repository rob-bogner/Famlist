    " " : {

    },
    "-" : {
      "comment" : "Label for decrementing a quantity.",
      "isCommentAutoGenerated" : true
    },
    "%@, %lld Artikel" : {
      "comment" : "An accessibility label that combines the category name with the number of items.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$@, %2$lld Artikel"
          }
        }
      }
    },
    "%lld" : {
      "comment" : "A label showing the current value of a quantity stepper. The text inside the parentheses is replaced with the current value of the stepper.",
      "isCommentAutoGenerated" : true
    },
    "%lld %@" : {
      "comment" : "Displays the number of units and, if present, the corresponding measure of a shopping list item.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld %2$@"
          }
        }
      }
    },
    "%lld%@" : {
      "comment" : "A label displaying the quantity of an imported item, optionally including its unit of measurement. The first argument is the count of the imported item's quantity. The second argument is the unit of measurement, if available.",
      "isCommentAutoGenerated" : true,
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "new",
            "value" : "%1$lld%2$@"
          }
        }
      }
    },
    "+" : {
      "comment" : "A button label that increments a value.",
      "isCommentAutoGenerated" : true
    },
    "Abbrechen" : {
